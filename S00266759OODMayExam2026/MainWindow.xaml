<Window x:Class="S00266759OODMayExam2026.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:S00266759OODMayExam2026"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left : Members -->
        <StackPanel Grid.Column="0">

            <TextBlock x:Name="tblkMembers" 
               Text="Members"
               FontWeight="Bold"
               Margin="5"/>

            <ListBox x:Name="lbxMembers"
             DisplayMemberPath="FirstName"
             Height="500"/>
        </StackPanel>

        <!-- Right Side -->
        <StackPanel Grid.Column="1" Margin="10">

            <!-- Member Details -->
            <TextBlock x:Name ="tblkMemberDetails" 
               Text="Member Details"
               FontWeight="Bold"
               Margin="5"/>

            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ID:" Grid.Row="0" Grid.Column="0"/>
                <TextBlock x:Name="tblkMemberId" Grid.Row="0" Grid.Column="1"/>

                <TextBlock Text="First Name:" Grid.Row="1" Grid.Column="0"/>
                <TextBlock x:Name="tblkFirstName" Grid.Row="1" Grid.Column="1"/>

                <TextBlock Grid.Row="2" Grid.Column="0"><Run Text="L"/><Run Text="ast"/><Run Text="Na"/><Run Text="me:"/></TextBlock>
                <TextBlock x:Name="tblkLastName" Grid.Row="2" Grid.Column="1"/>

                <TextBlock Text="Contact Number:" Grid.Row="3" Grid.Column="0"/>
                <TextBlock x:Name="tblkContactNum" Grid.Row="3" Grid.Column="1"/>

                <TextBlock Text="Membership Type:" Grid.Row="4" Grid.Column="0"/>
                <TextBlock x:Name="tblkMembershipType" Grid.Row="4" Grid.Column="1"/>

                <TextBlock Text="DOB:" Grid.Row="5" Grid.Column="0"/>
                <TextBlock x:Name="tblkDOB" Grid.Row="5" Grid.Column="1"/>
            </Grid>

            <!-- Training Sessions -->
            <TextBlock x:Name ="tblkTrainingSessions"
               Text="Training Sessions"
               FontWeight="Bold"
               Margin="10,20,5,5"/>

            <Button x:Name="btnAddSession"
            Content="Add Session"
            Width="120"
            Height="30"
            Margin="5"/>

            <ListBox x:Name="lbxSessions"
             Height="200"
             Margin="5">
                
            </ListBox>

        </StackPanel>
    </Grid>
</Window>
